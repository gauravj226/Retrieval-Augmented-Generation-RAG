SECRET_KEY=your-super-secret-key-minimum-32-characters

CHROMA_HOST=chromadb
CHROMA_PORT=8000

OLLAMA_HOST=ollama
OLLAMA_PORT=11434
DEFAULT_LLM_MODEL=llama3.2:3b
VLM_MODEL=qwen2.5vl:3b

DATABASE_URL=sqlite:////app/data/rag_system.db
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_FILES=5
MAX_UPLOAD_FILE_MB=15
MAX_UPLOAD_BATCH_MB=50
HYBRID_LEXICAL_MAX_DOCS=2000
ENABLE_CROSS_ENCODER_RERANK=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FAST_MODE=true
QUERY_CACHE_TTL_SEC=120
QUERY_CACHE_MAX=256
INGEST_WORKERS=2
INGEST_QUEUE_MAX=200
VLM_MAX_PAGES=8
VLM_DPI=120
VLM_CONCURRENCY=2
VLM_TIMEOUT_SEC=75
VISUAL_MAX_PDF_PAGES=8
VISUAL_MAX_PDF_MB=4
AUDIT_LOG_PATH=/app/logs/audit.log
AUDIT_LOG_LEVEL=INFO

# ── Windows SSL path (forward slashes required for Docker Desktop) ───────────
SSL_DIR=C:/rag-platform/ssl

# ── Force polling so watchfiles works through Docker Desktop WSL2 layer ──────
WATCHFILES_FORCE_POLLING=true
WATCHFILES_FORCE_POLLING_DELAY=500
