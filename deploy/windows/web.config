<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. API Reverse Proxy: Forward /api/* to FastAPI on port 8000 -->
        <rule name="RAG Backend API" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/{R:0}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>

        <!-- 2. Frontend Reverse Proxy: Forward everything else to Nginx on port 3000 -->
        <rule name="RAG Frontend" stopProcessing="true">
          <match url="^(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <add name="X-Forwarded-Proto" value="https" />
      </customHeaders>
    </httpProtocol>

    <!-- Support for WebSockets if needed -->
    <webSocket enabled="true" />
  </system.webServer>
</configuration>
